<?xml version="1.0" encoding="utf-8"?>
<!-- Sidebar item background with ripple effect (Desktop match) -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/sidebar_item_hover">
    <item>
        <selector>
            <item android:state_selected="true">
                <shape android:shape="rectangle">
                    <solid android:color="@color/sidebar_item_active" />
                    <corners android:radius="@dimen/corner_radius_small" />
                </shape>
            </item>
            <item android:state_pressed="true">
                <shape android:shape="rectangle">
                    <solid android:color="@color/sidebar_item_hover" />
                    <corners android:radius="@dimen/corner_radius_small" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/transparent" />
                    <corners android:radius="@dimen/corner_radius_small" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>
