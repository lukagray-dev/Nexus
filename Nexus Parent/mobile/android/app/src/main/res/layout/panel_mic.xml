<?xml version="1.0" encoding="utf-8"?>
<!-- Mic Feature Panel -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/panel_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_medium"
    app:cardBackgroundColor="@color/panel_background"
    app:cardCornerRadius="@dimen/corner_radius_large"
    app:cardElevation="@dimen/elevation_medium"
    app:strokeColor="@color/border_primary"
    app:strokeWidth="@dimen/border_width">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Panel Header -->
        <androidx.constraintlayout.widget.ConstraintLayout
            style="@style/PanelHeaderStyle">

            <!-- Feature Icon -->
            <ImageView
                android:id="@+id/panel_icon"
                android:layout_width="@dimen/icon_size_normal"
                android:layout_height="@dimen/icon_size_normal"
                android:src="@drawable/ic_mic"
                android:contentDescription="@string/feature_mic"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:tint="@color/accent_primary" />

            <!-- Feature Title -->
            <TextView
                android:id="@+id/panel_title"
                style="@style/PanelTitleStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_medium"
                android:layout_marginEnd="@dimen/spacing_medium"
                android:text="@string/feature_mic"
                app:layout_constraintStart_toEndOf="@id/panel_icon"
                app:layout_constraintEnd_toStartOf="@id/mic_status_indicator"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Status Indicator (Pulsing Dot) -->
            <View
                android:id="@+id/mic_status_indicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/status_indicator"
                android:layout_marginEnd="12dp"
                app:layout_constraintEnd_toStartOf="@id/panel_close"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Close Button -->
            <ImageView
                android:id="@+id/panel_close"
                android:layout_width="@dimen/icon_size_normal"
                android:layout_height="@dimen/icon_size_normal"
                android:contentDescription="@string/close"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:tint="@color/text_secondary" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/border_width"
            android:background="@color/border_primary" />

        <!-- Panel Content Container -->
        <FrameLayout
            android:id="@+id/panel_content"
            android:layout_width="match_parent"
            android:layout_height="400dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="#000000">
                
                <!-- Mic Visualizer Container -->
                <FrameLayout
                    android:id="@+id/mic_visualizer_container"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="#000000">
                    
                    <!-- Placeholder -->
                    <LinearLayout
                        android:id="@+id/mic_placeholder"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="32dp">
                        
                        <ImageView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:src="@drawable/ic_mic"
                            android:alpha="0.3"
                            app:tint="#e4e4e7" />
                        
                        <TextView
                            android:id="@+id/mic_placeholder_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Audio visualizer will appear here"
                            android:textSize="12sp"
                            android:textColor="#a1a1aa"
                            android:layout_marginTop="12dp"
                            android:gravity="center" />
                        
                    </LinearLayout>
                    
                    <!-- Visualizer Canvas (will be added programmatically) -->
                    
                    <!-- Mute/Unmute Button Container (Bottom Left) -->
                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:layout_margin="16dp">
                        
                        <!-- Pulsing animation ring (behind button) -->
                        <View
                            android:id="@+id/mic_pulse_ring"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_gravity="center"
                            android:background="@drawable/pulse_ring"
                            android:visibility="gone"
                            android:alpha="0" />
                        
                        <!-- Mute/Unmute Button -->
                        <ImageView
                            android:id="@+id/mic_mute_btn"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_mic_mute"
                            android:padding="12dp"
                            android:background="@drawable/stream_control_btn_background" />
                    </FrameLayout>
                    
                    <!-- Play/Pause Button (Bottom Right) -->
                    <ImageView
                        android:id="@+id/mic_play_pause_btn"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="16dp"
                        android:src="@drawable/ic_play"
                        android:padding="12dp"
                        android:background="@drawable/stream_control_btn_background"
                        app:tint="#000000" />
                    
                </FrameLayout>
                
                <!-- Mic Info Footer -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:background="#18181B">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sample Rate:"
                        android:textSize="12sp"
                        android:textColor="#a1a1aa"
                        android:layout_marginEnd="8dp" />
                    
                    <TextView
                        android:id="@+id/mic_sample_rate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="44.1 kHz"
                        android:textSize="12sp"
                        android:textColor="#e4e4e7"
                        android:textStyle="bold"
                        android:layout_marginEnd="16dp" />
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Channels:"
                        android:textSize="12sp"
                        android:textColor="#a1a1aa"
                        android:layout_marginEnd="8dp" />
                    
                    <TextView
                        android:id="@+id/mic_channels"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mono"
                        android:textSize="12sp"
                        android:textColor="#e4e4e7"
                        android:textStyle="bold" />
                    
                </LinearLayout>
                
            </LinearLayout>
            
        </FrameLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
