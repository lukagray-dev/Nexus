<?xml version="1.0" encoding="utf-8"?>
<!-- AI welcome message -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="@dimen/spacing_large">

    <!-- AI Avatar -->
    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_ai"
        app:tint="@color/accent_primary" />

    <!-- Welcome Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_medium"
        android:text="Welcome to Nexus Assistant"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Welcome Description -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_small"
        android:text="Ask me anything about Nexus:"
        android:textColor="@color/text_secondary"
        android:textSize="16sp" />

    <!-- Feature List -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_medium"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• Camera &amp; Screen streaming"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• Location tracking"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• Messages &amp; Call logs"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• Notifications monitoring"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

    </LinearLayout>

</LinearLayout>
