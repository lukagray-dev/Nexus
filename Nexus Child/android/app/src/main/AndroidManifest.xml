<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <permission android:name="nexus.android.child.PERMISSION_CONNECTION_STATUS"
        android:protectionLevel="signature" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <!-- Camera Permission -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Audio Permission -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Foreground Service Permission -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"
        tools:ignore="ForegroundServicesPolicy" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.CAPTURE_VIDEO_OUTPUT" tools:ignore="ProtectedPermissions"/>
    <!-- Alert Window Permission -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- Notification Permission -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Wake Lock Permission -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Auto Start Permission -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.QUICKBOOT_POWERON" />
    <!-- SMS Permission -->
    <uses-permission android:name="android.permission.RECEIVE_SMS"
        tools:ignore="SmsAndCallLogPolicy" />
    <uses-permission android:name="android.permission.READ_SMS"
        tools:ignore="SmsAndCallLogPolicy" />
    <!-- Call Log Permission -->
    <uses-permission android:name="android.permission.READ_CALL_LOG"
        tools:ignore="SmsAndCallLogPolicy" />
    <!-- Location permissions -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION"
        tools:ignore="BackgroundLocationPolicy" />
    <!-- Call Recording Permissions -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <!--suppress DeprecatedClassUsageInspection -->
    <uses-permission android:name="android.permission.PROCESS_OUTGOING_CALLS"
        tools:ignore="SmsAndCallLogPolicy" />
    <uses-permission android:name="android.permission.CAPTURE_AUDIO_OUTPUT" tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.WRITE_SETTINGS" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="AllFilesAccessPolicy,ScopedStorage" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"
        tools:ignore="PhotoAndVideoPolicy,SelectedPhotoAccess" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO"
        tools:ignore="PhotoAndVideoPolicy,SelectedPhotoAccess" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <!-- Missing Permissions -->
    <uses-permission android:name="android.permission.ACCESS_MEDIA_LOCATION" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <!-- Digital Wellbeing Permissions -->
    <!-- PACKAGE_USAGE_STATS for older Android versions (pre-API 31) -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <!-- QUERY_ALL_PACKAGES for modern Android (API 31+) -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />
    <!-- Unrestricted Data Permission -->
    <uses-permission android:name="android.permission.UNRESTRICTED_DATA"
        tools:ignore="ProtectedPermissions" />
    <!-- Wallpaper Permission -->
    <uses-permission android:name="android.permission.SET_WALLPAPER" />
    <!-- Vibration Permission -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Network State Permission -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.INTERNET" />

    <queries>
        <intent>
            <action android:name="miui.intent.action.CALL_RECORDING_SETTINGS" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Child"
        tools:targetApi="31">
        <activity
            android:name="nexus.android.child.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Child">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="nexus.android.child.permissions.PermissionGuideActivity"
            android:exported="false"
            android:theme="@style/Theme.Child" />

        <activity
            android:name="nexus.android.child.customization.IconSelectionActivity"
            android:exported="false"
            android:theme="@style/Theme.Child" />

        <activity
            android:name="nexus.android.child.customization.FakeUIActivity"
            android:exported="false"
            android:theme="@style/Theme.Child.Fullscreen" />

        <activity
            android:name="nexus.android.child.applock.AppLockActivity"
            android:exported="false"
            android:theme="@style/Theme.Child"
            android:screenOrientation="fullSensor"
            android:launchMode="singleTop" />

        <activity
            android:name="nexus.android.child.applock.AppLockSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.Child" />

        <!-- Transparent activity for MediaProjection permission -->
        <activity
            android:name="nexus.android.child.components.screen.TransparentMediaProjectionActivity"
            android:theme="@style/TransparentActivity"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance"
            android:taskAffinity=""
            android:exported="false" />

